# ========================
# OptiRisk Monorepo .gitignore
# ========================

# --- Node / Frontend ---
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/.vercel/
frontend/.env
frontend/.env*.local
*.tsbuildinfo
next-env.d.ts

# --- C++ / Backend ---
backend/build/
backend/cmake-build-*/
backend/CMakeFiles/
backend/CMakeCache.txt
backend/cmake_install.cmake
backend/Makefile
backend/compile_commands.json
backend/*.o
backend/*.a
backend/*.so
backend/*.dylib
*.dSYM/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Environment ---
.env
.env.local 
.env.development.local
.env.test.local
.env.production.local

# --- Misc ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
